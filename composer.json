{
    "name": "sgray-circle8/graydojo",
    "description": "Bujinkan Gray Dojo",
    "autoload": {
        "classmap": [
            "app/src/Page.php",
            "app/src/PageController.php"
        ],
        "psr-4": {
            "App\\": "app/src/"
        }
    },
    "require": {
        "php": "^8.3",
        "dnadesign/silverstripe-elemental": "^6",
        "silverstripe/blog": "^5",
        "silverstripe/htmleditor-tinymce": "1.0.2",
        "silverstripe/login-forms": "^6",
        "silverstripe/recipe-cms": "6.1",
        "silverstripe/userforms": "^7",
        "undefinedoffset/silverstripe-nocaptcha": "^3.1"
    },
    "require-dev": {
        "phpstan/extension-installer": "^1.4",
        "phpunit/phpunit": "^11.5",
        "silverstripeltd/bespoke-standards": "^1.6",
        "wernerkrauss/silverstripe-rector": "*"
    },
    "config": {
        "sort-packages": true,
        "process-timeout": 600,
        "allow-plugins": {
            "composer/installers": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "php-http/discovery": true,
            "phpstan/extension-installer": true,
            "silverstripe/recipe-plugin": true,
            "silverstripe/vendor-plugin": true
        }
    },
    "extra": {
        "expose": [
            "themes/app/dist"
        ],
        "project-files": [
            "app/_config/*",
            ".env.example"
        ],
        "project-files-installed": [
            ".htaccess",
            "app/.htaccess",
            "app/_config.php",
            "app/_config/mimevalidator.yml",
            "app/_config/mysite.yml",
            "app/src/Page.php",
            "app/src/PageController.php"
        ],
        "public-files": [
            "assets/*",
            "favicon.ico"
        ],
        "public-files-installed": [
            ".htaccess",
            "index.php",
            "web.config"
        ],
        "resources-dir": "_resources"
    },
    "prefer-stable": true,
    "minimum-stability": "dev"
}
