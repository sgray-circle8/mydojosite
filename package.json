{
  "name": "mydojosite",
  "version": "1.0.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sgray-circle8/mydojosite.git"
  },
  "author": {
    "name": "Shawn Gray",
    "email": "s.gray@circle-eight.com"
  },
  "license": "MIT",
  "scripts": {
    "dev": "npx mix",
    "watch": "npx mix watch",
    "build": "cross-env NODE_ENV=production npx mix --production",
    "prettier:check": "prettier --check themes/app/src/**/*.{scss,vue}",
    "prettier:write": "prettier --write themes/app/src/**/*.{scss,vue}",
    "test": "yarn test:e2e && yarn test:coverage",
    "test:e2e": "cypress run --browser chrome",
    "test:coverage": "node nyc-coverage.js",
    "lint:css": "stylelint themes/app/src/scss/**/*.scss themes/app/src/js/**/*.vue",
    "lint:js": "eslint --ext .js,.vue themes/app/src/js",
    "lint": "yarn lint:css && yarn lint:js"
  },
  "devDependencies": {
    "@babel/core": "^7.21.3",
    "@babel/eslint-parser": "^7.28.5",
    "@badeball/cypress-cucumber-preprocessor": "^16.0.1",
    "@bahmutov/cypress-esbuild-preprocessor": "^2.2.0",
    "@cypress/code-coverage": "^3.10.1",
    "@types/jest": "^29.2.5",
    "@typescript-eslint/eslint-plugin": "^5.48.1",
    "@typescript-eslint/parser": "^5.48.1",
    "@vue/compiler-sfc": "^3.2.47",
    "@vue/test-utils": "^2.3.2",
    "@vue/vue3-jest": "^29.2.3",
    "babel-jest": "^29.5.0",
    "babel-loader": "^9.1.2",
    "babel-plugin-istanbul": "^6.0.0",
    "bootstrap": "^5.2.3",
    "browser-sync": "^2.29.1",
    "browser-sync-webpack-plugin": "^2.3.0",
    "chromatic": "^6.19.9",
    "cross-env": "^7.0.3",
    "cypress": "^12.9.0",
    "dotenv": "^16.0.3",
    "eslint": "^8.37.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-vue": "^9.10.0",
    "eslint-webpack-plugin": "^4.0.0",
    "fs-extra": "^11.1.1",
    "html-webpack-plugin": "^5.5.0",
    "jest": "^29.5.0",
    "jest-environment-jsdom": "^29.5.0",
    "jest-junit": "^15.0.0",
    "jest-serializer-vue": "^3.1.0",
    "laravel-mix": "^6.0.49",
    "node-sass-glob-importer": "^5.3.2",
    "nyc": "^15.1.0",
    "postcss": "^8.4.21",
    "postcss-html": "^1.5.0",
    "postcss-scss": "^4.0.6",
    "prettier": "^2.8.7",
    "resolve-url-loader": "^5.0.0",
    "sass": "^1.60.0",
    "sass-loader": "^13.2.2",
    "stylelint": "^15.3.0",
    "stylelint-config-prettier": "^9.0.5",
    "stylelint-config-recommended-vue": "^1.4.0",
    "stylelint-config-standard": "^28.0.0",
    "stylelint-scss": "^4.6.0",
    "stylelint-webpack-plugin": "^4.1.0",
    "ts-jest": "^27.1.5",
    "typescript": "^5.0.2",
    "vue-loader": "^17.0.1",
    "webpack": "^5.74.0"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "focus-trap": "^7.5.2",
    "focus-trap-vue": "^4.0.2",
    "highcharts": "^11.4.8",
    "promise-polyfill": "^8.2.0",
    "v-calendar": "^3.1.2",
    "vue": "^3.2.47",
    "vuex": "^4.0"
  },
  "cypress-cucumber-preprocessor": {
    "stepDefinitions": [
      "cypress/e2e/[filepath]/**/*.{js,ts}",
      "cypress/e2e/[filepath].{js,ts}",
      "cypress/e2e/common/**/*.{js,ts}"
    ]
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "ts",
      "json",
      "vue"
    ],
    "testEnvironment": "jsdom",
    "testEnvironmentOptions": {
      "customExportConditions": [
        "node",
        "node-addons"
      ]
    },
    "transform": {
      "^.*\\.vue$": "<rootDir>/node_modules/@vue/vue3-jest",
      "^.+\\.js$": "<rootDir>/node_modules/babel-jest"
    },
    "snapshotSerializers": [
      "jest-serializer-vue"
    ],
    "collectCoverage": true,
    "coverageDirectory": "coverage/jest"
  },
  "nyc": {
    "extension": [
      ".js",
      ".vue"
    ],
    "report-dir": "coverage/cypress"
  }
}
