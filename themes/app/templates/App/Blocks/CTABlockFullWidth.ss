<section class="cta-block card hero">
  <div class="hero-inner">
    <div class="hero-text">
      <h1 class="cta-block__title">$Title</h1>
      <div class="cta-block__summary--wrapper">
        <div class="cta-block__summary">$CTASummary</div>
        <div class="cta-block__button"><a class="btn" href="$CTAButtonPage.Link">$CTAButtonText</a></div>
      </div>
    </div>
  </div>
</section>